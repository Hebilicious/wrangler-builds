{
  "name": "@hebilicious/wrangler-builds",
  "version": "0.1.0",
  "description": "Project-agnostic Cloudflare Workers Build trigger sync package.",
  "type": "module",
  "packageManager": "pnpm@10.16.1",
  "types": "./dist/index.d.mts",
  "bin": {
    "wrangler-builds": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "README.md",
    "dist",
    "schema"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hebilicious/wrangler-builds.git",
    "directory": "packages/wrangler-builds"
  },
  "homepage": "https://github.com/Hebilicious/wrangler-builds/tree/main/packages/wrangler-builds",
  "bugs": {
    "url": "https://github.com/Hebilicious/wrangler-builds/issues"
  },
  "scripts": {
    "sync-readme": "node ./scripts/sync-readme.mjs",
    "prepack": "pnpm run sync-readme"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=24.5.0"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "wrangler",
    "builds",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "ajv": "catalog:",
    "citty": "catalog:",
    "jsonc-parser": "catalog:",
    "tinyglobby": "catalog:"
  },
  "devDependencies": {
    "@cucumber/cucumber": "catalog:",
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsx": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
